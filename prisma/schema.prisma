generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  logoUrl       String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  projects      ComplianceProject[]
  members       OrgMember[]
  subscriptions Subscription[]
}

model OrgMember {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  role         OrgRole      @default(MEMBER)
  createdAt    DateTime     @default(now())
  organisation Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  avatarUrl            String?
  emailVerified        DateTime?
  passwordHash         String?
  phone                String?
  marketingConsent     Boolean               @default(false)
  onboardingDone       Boolean               @default(false)
  mfaSecret            String?
  mfaEnabled           Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  comments             ControlComment[]
  assignedTasks        ControlTask[]
  orgMembers           OrgMember[]
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IsoStandard {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  description String?
  version     String
  createdAt   DateTime            @default(now())
  projects    ComplianceProject[]
  clauses     IsoClause[]
}

model IsoClause {
  id           String       @id @default(cuid())
  standardId   String
  clauseNumber String
  title        String
  description  String?
  parentId     String?
  parent       IsoClause?   @relation("ClauseHierarchy", fields: [parentId], references: [id])
  children     IsoClause[]  @relation("ClauseHierarchy")
  standard     IsoStandard  @relation(fields: [standardId], references: [id])
  controls     IsoControl[]

  @@index([standardId])
}

model IsoControl {
  id              String           @id @default(cuid())
  clauseId        String
  controlRef      String
  title           String
  description     String?
  guidance        String?
  clause          IsoClause        @relation(fields: [clauseId], references: [id])
  projectControls ProjectControl[]

  @@index([clauseId])
}

model ComplianceProject {
  id           String           @id @default(cuid())
  orgId        String
  standardId   String
  name         String
  targetDate   DateTime?
  status       ProjectStatus    @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  description  String?
  leadUserId   String?
  startDate    DateTime?
  organisation Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  standard     IsoStandard      @relation(fields: [standardId], references: [id])
  controls     ProjectControl[]

  @@index([orgId])
}

model ProjectControl {
  id        String            @id @default(cuid())
  projectId String
  controlId String
  status    ControlStatus     @default(NOT_STARTED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  comments  ControlComment[]
  tasks     ControlTask[]
  evidence  Evidence[]
  control   IsoControl        @relation(fields: [controlId], references: [id])
  project   ComplianceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, controlId])
}

model Evidence {
  id               String             @id @default(cuid())
  projectControlId String
  name             String
  description      String?
  fileUrl          String?
  fileType         String?
  fileSize         Int?
  uploadedBy       String
  createdAt        DateTime           @default(now())
  classification   DataClassification @default(INTERNAL)
  updatedAt        DateTime           @updatedAt
  projectControl   ProjectControl     @relation(fields: [projectControlId], references: [id], onDelete: Cascade)

  @@index([projectControlId])
}

model ControlTask {
  id               String         @id @default(cuid())
  projectControlId String
  title            String
  description      String?
  assigneeId       String?
  dueDate          DateTime?
  status           TaskStatus     @default(TODO)
  priority         TaskPriority   @default(MEDIUM)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignee         User?          @relation(fields: [assigneeId], references: [id])
  projectControl   ProjectControl @relation(fields: [projectControlId], references: [id], onDelete: Cascade)

  @@index([projectControlId])
  @@index([assigneeId])
}

model ControlComment {
  id               String         @id @default(cuid())
  projectControlId String
  authorId         String
  body             String
  createdAt        DateTime       @default(now())
  author           User           @relation(fields: [authorId], references: [id])
  projectControl   ProjectControl @relation(fields: [projectControlId], references: [id], onDelete: Cascade)

  @@index([projectControlId])
  @@index([authorId])
}

model Subscription {
  id                   String             @id @default(cuid())
  orgId                String
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organisation         Organisation       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ControlStatus {
  NOT_STARTED
  IN_PROGRESS
  IMPLEMENTED
  NOT_APPLICABLE
  NON_COMPLIANT
}

enum DataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  userName  String
  action    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt(sort: Desc)])
}
